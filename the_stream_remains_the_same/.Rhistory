# Loop para processar cada URL na lista
for (url in names(url_m3u8)) {
# Faz o download do conteúdo da URL
response <- GET(url)
conteudo <- content(response, "text", encoding = "UTF-8")
# Verifica se a tag "group-title" já existe no conteúdo
if (!grepl('group-title="', conteudo)) {
# Se "group-title" não existe, insere a tag antes de cada "#EXTINF:"
nome_grupo <- url_m3u8[[url]]
conteudo <- gsub("#EXTINF:-1,", sprintf("#EXTINF:-1 group-title=\"%s\",", nome_grupo), conteudo)
}
# Armazena o conteúdo modificado em uma variável com o nome do grupo
assign(url_m3u8[[url]], conteudo, envir = .GlobalEnv)
# Adiciona o conteúdo modificado ao conteúdo final
final <- paste(final, conteudo, sep = "\n")
}
# Opcional: Salva o conteúdo final em um arquivo
writeLines(final, "conteudo_final.m3u8")
# Carregar o pacote stringr para manipulação de strings
library(stringr)
# Ler o arquivo m3u8 original
arquivo_original <- readLines("conteudo_final.m3u8")
# Função para substituir os valores da tag "group-title"
substituir_categoria <- function(linha) {
# Usando case_when-like logic com if_else devido ao contexto de vetorização
linha <- if_else(str_detect(linha, "Kids|Infantis em|Family|Animation;Kids"),
str_replace(linha, "(?<=group-title=\").*?(?=\")", "Infantil e Família"), linha)
linha <- if_else(str_detect(linha, "Animation;Classic|Anime & Geek|Comedy|Entertainment|Culture"),
str_replace(linha, "(?<=group-title=\").*?(?=\")", "Entretenimento e Cultura"), linha)
linha <- if_else(str_detect(linha, "Education|Documentary|Brasil: educativos e documentários"),
str_replace(linha, "(?<=group-title=\").*?(?=\")", "Educação e Documentários"), linha)
linha <- if_else(str_detect(linha, "News|Notícias"),
str_replace(linha, "(?<=group-title=\").*?(?=\")", "Notícias e Jornalismo"), linha)
linha <- if_else(str_detect(linha, "Esportes|Sports"),
str_replace(linha, "(?<=group-title=\").*?(?=\")", "Esportes"), linha)
linha <- if_else(str_detect(linha, "Music|Música"),
str_replace(linha, "(?<=group-title=\").*?(?=\")", "Música e Artes"), linha)
linha <- if_else(str_detect(linha, "Lifestyle|Reality"),
str_replace(linha, "(?<=group-title=\").*?(?=\")", "Estilo de Vida e Realidades"), linha)
linha <- if_else(str_detect(linha, "Variedades|BRASIL|Brasil:"),
str_replace(linha, "(?<=group-title=\").*?(?=\")", "Variedades e Outros"), linha)
return(linha)
}
# Aplicar a função a cada linha do arquivo
arquivo_modificado <- sapply(arquivo_original, substituir_categoria)
# Salvar o arquivo modificado
writeLines(arquivo_modificado, "lista_iptv_modificado.m3u8")
# Define o caminho para o arquivo M3U8 unificado
arquivo <- "conteudo_final.m3u8"
# Lê o conteúdo do arquivo
conteudo <- readLines(arquivo, warn = FALSE)
# Filtra as linhas que contêm a tag "group-title"
linhas_com_group_title <- grep("group-title", conteudo, value = TRUE)
# Extrai os valores da tag "group-title"
valores_group_title <- sapply(linhas_com_group_title, function(linha) {
matches <- regmatches(linha, regexec('group-title="([^"]+)"', linha))
if (length(matches[[1]]) > 1) matches[[1]][2] else NA
})
# Remove possíveis valores NA resultantes de linhas mal formatadas
valores_group_title <- na.omit(valores_group_title)
# Calcula a frequência de cada valor de "group-title"
tabulacao <- as.data.frame(table(valores_group_title))
# Exibe a tabulação
print(tabulacao)
writexl::write_xlsx(tabulacao, "tabulacao_conteudo_final.xlsx")
tabulacao
