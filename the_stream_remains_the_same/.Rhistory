library(stringr)
library(dplyr)
# Define as URLs de onde os dados serão extraídos
url_m3u8 <- c("https://i.mjh.nz/PlutoTV/br.m3u8",
"https://iptv-org.github.io/iptv/countries/br.m3u",
"https://www.apsattv.com/ssungbra.m3u",
"https://lib.bz/br.m3u",
"https://raw.githubusercontent.com/helenfernanda/gratis/main/iptvlegal.m3u")
# Inicializa as variáveis para contar os canais
total_channels_before_filter <- 0
total_channels_after_filter <- 0
# Inicializa a variável final que conterá todos os canais filtrados
final <- ""
# Inicializa um vetor para armazenar os valores de 'group-title'
group_titles <- c()
# Loop por cada URL para extrair e filtrar o conteúdo
for(url in url_m3u8) {
# Realiza a solicitação HTTP GET para a URL
response <- GET(url)
# Verifica se a solicitação foi bem-sucedida
if(status_code(response) == 200) {
# Extrai o conteúdo da resposta
content <- content(response, "text", encoding = "UTF-8")
# Separa o conteúdo em linhas
lines <- str_split(content, "\n")[[1]]
# Conta quantos canais foram encontrados antes do filtro
total_channels_before_filter <- total_channels_before_filter + sum(str_detect(lines, "#EXTINF"))
# Filtra as linhas que contêm referências ao Brasil
brazil_lines <- lines[str_detect(lines, "(Brazil|brazil|Brasil|brasil|\\(br\\)|BR|portuguese|portugues|português)")]
# Conta quantos canais foram mantidos após o filtro
total_channels_after_filter <- total_channels_after_filter + sum(str_detect(brazil_lines, "#EXTINF"))
# Concatena as linhas filtradas à variável final
final <- paste(final, paste(brazil_lines, collapse = "\n"), sep = "\n")
# Extrai os valores de 'group-title' e os adiciona ao vetor
titles <- str_extract_all(brazil_lines, "(?<=group-title=\")[^\"]*") %>% unlist()
group_titles <- c(group_titles, titles)
}
}
# Remove linhas vazias que podem ter sido adicionadas
final <- str_trim(final)
# Exibe o número de canais encontrados e o número de canais mantidos após o filtro
cat("\nNúmero total de canais encontrados: ", total_channels_before_filter, "\n")
cat("Número de canais mantidos após filtrar para o Brasil: ", total_channels_after_filter, "\n")
# Tabula os valores de 'group-title'
group_title_table <- table(group_titles)
# Exibe a tabulação dos valores de 'group-title'
cat("\nTabulação dos valores de 'group-title':\n")
print(group_title_table)
