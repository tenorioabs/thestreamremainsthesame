final <- paste(final, paste(brazil_lines, collapse = "\n"), sep = "\n")
# Extrai os valores de 'group-title' e os adiciona ao vetor
titles <- str_extract_all(brazil_lines, "(?<=group-title=\")[^\"]*") %>% unlist()
group_titles <- c(group_titles, titles)
}
}
# Remove linhas vazias que podem ter sido adicionadas
final <- str_trim(final)
# Salva o conteúdo filtrado em um arquivo
writeLines(final, "canais_filtrados.m3u")
# Exibe o número de canais encontrados e o número de canais mantidos após o filtro
cat("\nNúmero total de canais encontrados: ", total_channels_before_filter, "\n")
cat("Número de canais mantidos após filtrar para o Brasil: ", total_channels_after_filter, "\n")
# Tabula os valores de 'group-title'
group_title_table <- table(group_titles)
# Exibe a tabulação dos valores de 'group-title'
cat("\nTabulação dos valores de 'group-title':\n")
print(group_title_table)
# Informa ao usuário que o arquivo foi salvo
cat("\nOs canais filtrados foram salvos no arquivo 'canais_filtrados.m3u'")
