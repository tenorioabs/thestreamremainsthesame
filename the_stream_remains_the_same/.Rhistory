# Função para substituir valores de group-title com categorização completa
substituir_group_title <- function(linhas) {
sapply(linhas, function(linha) {
group_title <- str_extract(linha, "(?<=group-title=')[^']+(?=')")
novo_group_title <- case_when(
group_title %in% c("Animation", "Animation;Classic", "Animation;Classic;Entertainment;Family;Movies",
"Animation;Classic;Kids", "Animation;Culture;Entertainment", "Animation;Entertainment;Movies;Series",
"Animation;Kids", "Animation;Kids;Music", "Animation;Kids;Religious") ~ "Animação",
group_title == "Anime & Geek" ~ "Anime e Geek",
group_title == "Auto" | group_title == "Auto;Entertainment" ~ "Automotivo",
group_title == "Business" | group_title == "Business;Legislative;News" |
group_title == "Business;News" | group_title == "Business;Sports" ~ "Negócios",
group_title == "Comedy" | group_title == "Comedy;Movies" | group_title == "Comedy;Series" |
group_title == "Comédia" ~ "Comédia",
group_title == "Cooking" | group_title == "Cooking;Shop" ~ "Culinária",
group_title == "Documentary" | group_title == "Documentary;Education" | group_title == "Documentário" |
group_title == "Documentary;Entertainment;News" | group_title == "Documentary;Lifestyle" |
group_title == "Documentary;News" | group_title == "Documentary;Science" |
group_title == "Documentary;Travel" ~ "Documentário",
group_title == "Education" | group_title == "Education;General" | group_title == "Education;Kids" |
group_title == "Education;Outdoor" | group_title == "Education;Science" ~ "Educação",
group_title == "Entertainment" | group_title == "Entertainment;Family" |
group_title == "Entertainment;Music" | group_title == "Entertainment;Series" |
group_title == "Entretenimento" ~ "Entretenimento",
group_title == "Family" | group_title == "Family;General" | group_title == "Family;Movies" |
group_title == "Family;Religious" ~ "Família",
group_title == "Kids" | group_title == "Kids;Music" | group_title == "Kids;Religious" |
group_title == "Infantil" ~ "Infantil",
group_title == "Movies" | group_title == "Movies;Music" | group_title == "Movies;News" |
group_title == "Movies;Series" | group_title == "Filmes" ~ "Cinema",
group_title == "Music" | group_title == "Music;News" | group_title == "Music;Religious" |
group_title == "Música" | group_title == "Música instrumental e som ambiente" ~ "Música",
group_title == "News" | group_title == "News;Religious" | group_title == "Notícias" |
group_title == "Notícias em espanhol" ~ "Notícias",
group_title == "Sports" | group_title == "Esportes" ~ "Esportes",
TRUE ~ group_title # Mantém o valor original se não houver correspondência
)
str_replace(linha, paste0("group-title='", group_title, "'"), paste0("group-title='", novo_group_title, "'"))
})
}
final <- substituir_group_title(final)
# Opcional: Salva o conteúdo final em um arquivo
writeLines(final, "conteudo_final.m3u8")
# Define o caminho para o arquivo M3U8 unificado
arquivo <- "conteudo_final.m3u8"
# Lê o conteúdo do arquivo
conteudo <- readLines(arquivo, warn = FALSE)
# Filtra as linhas que contêm a tag "group-title"
linhas_com_group_title <- grep("group-title", conteudo, value = TRUE)
# Extrai os valores da tag "group-title"
valores_group_title <- sapply(linhas_com_group_title, function(linha) {
matches <- regmatches(linha, regexec('group-title="([^"]+)"', linha))
if (length(matches[[1]]) > 1) matches[[1]][2] else NA
})
# Remove possíveis valores NA resultantes de linhas mal formatadas
valores_group_title <- na.omit(valores_group_title)
# Calcula a frequência de cada valor de "group-title"
tabulacao <- as.data.frame(table(valores_group_title))
# Exibe a tabulação
print(tabulacao)
writexl::write_xlsx(tabulacao, "tabulacao_conteudo_final.xlsx")
