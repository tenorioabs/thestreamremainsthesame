# Função para substituir valores de group-title baseada em categorias específicas
substituir_group_title <- function(linha) {
group_title <- str_extract(linha, "(?<=group-title=')[^']+(?=')")
novo_group_title <- case_when(
group_title %in% c("Animation", "Animation;Classic", "Animation;Classic;Kids", "Animation;Kids") ~ "Animação",
group_title %in% c("Auto", "Auto;Entertainment") ~ "Auto",
group_title %in% c("Business", "Business;Legislative;News", "Business;News", "Business;Sports") ~ "Negócios",
group_title %in% c("Comedy", "Comedy;Movies", "Comedy;Series", "Comédia") ~ "Comédia",
group_title %in% c("Cooking", "Cooking;Shop", "Culinária em espanhol", "Culinária em inglês") ~ "Culinária",
group_title %in% c("Documentary", "Documentary;Education", "Documentário", "Documentários em alemão", "Documentários em espanhol") ~ "Documentário",
group_title %in% c("Education", "Education;General", "Education;Kids", "Education;Outdoor", "Education;Science") ~ "Educação",
group_title %in% c("Entertainment", "Entertainment;Family", "Entertainment;Music", "Entertainment;Series", "Entretenimento") ~ "Entretenimento",
group_title %in% c("Family", "Family;General", "Family;Movies", "Family;Religious") ~ "Família",
group_title %in% c("Kids", "Kids;Music", "Kids;Religious", "Infantil") ~ "Infantil",
group_title %in% c("Movies", "Movies;Music", "Movies;News", "Movies;Series", "Filmes") ~ "Cinema",
group_title %in% c("Music", "Music;News", "Music;Religious", "Música", "Música instrumental e som ambiente") ~ "Música",
group_title %in% c("News", "News;Religious", "Notícias", "Notícias em espanhol") ~ "Notícias",
group_title %in% c("Sports", "Esportes") ~ "Esportes",
TRUE ~ group_title # Mantém o valor original se não houver correspondência
)
# Substituir o valor antigo pelo novo no campo group-title
str_replace(linha, paste0("(group-title=')", group_title, "(')"), paste0("\\1", novo_group_title, "\\2"))
}
# Aplicar a função a cada elemento de 'final'
final <- sapply(final, substituir_group_title, USE.NAMES = FALSE)
# Opcional: Salva o conteúdo final em um arquivo
writeLines(final, "conteudo_final.m3u8")
# Define o caminho para o arquivo M3U8 unificado
arquivo <- "conteudo_final.m3u8"
# Lê o conteúdo do arquivo
conteudo <- readLines(arquivo, warn = FALSE)
# Filtra as linhas que contêm a tag "group-title"
linhas_com_group_title <- grep("group-title", conteudo, value = TRUE)
# Extrai os valores da tag "group-title"
valores_group_title <- sapply(linhas_com_group_title, function(linha) {
matches <- regmatches(linha, regexec('group-title="([^"]+)"', linha))
if (length(matches[[1]]) > 1) matches[[1]][2] else NA
})
# Remove possíveis valores NA resultantes de linhas mal formatadas
valores_group_title <- na.omit(valores_group_title)
# Calcula a frequência de cada valor de "group-title"
tabulacao <- as.data.frame(table(valores_group_title))
# Exibe a tabulação
print(tabulacao)
writexl::write_xlsx(tabulacao, "tabulacao_conteudo_final.xlsx")
# Função para substituir valores de group-title baseada em categorias específicas
substituir_group_title <- function(linha) {
group_title <- str_extract(linha, "(?<=group-title=')[^']+(?=')")
novo_group_title <- case_when(
group_title %in% c("Animation", "Animation;Classic", "Animation;Classic;Kids", "Animation;Kids") ~ "Animação",
group_title %in% c("Auto", "Auto;Entertainment") ~ "Auto",
group_title %in% c("Business", "Business;Legislative;News", "Business;News", "Business;Sports") ~ "Negócios",
group_title %in% c("Comedy", "Comedy;Movies", "Comedy;Series", "Comédia") ~ "Comédia",
group_title %in% c("Cooking", "Cooking;Shop", "Culinária em espanhol", "Culinária em inglês") ~ "Culinária",
group_title %in% c("Documentary", "Documentary;Education", "Documentário", "Documentários em alemão", "Documentários em espanhol") ~ "Documentário",
group_title %in% c("Education", "Education;General", "Education;Kids", "Education;Outdoor", "Education;Science") ~ "Educação",
group_title %in% c("Entertainment", "Entertainment;Family", "Entertainment;Music", "Entertainment;Series", "Entretenimento") ~ "Entretenimento",
group_title %in% c("Family", "Family;General", "Family;Movies", "Family;Religious") ~ "Família",
group_title %in% c("Kids", "Kids;Music", "Kids;Religious", "Infantil") ~ "Infantil",
group_title %in% c("Movies", "Movies;Music", "Movies;News", "Movies;Series", "Filmes") ~ "Cinema",
group_title %in% c("Music", "Music;News", "Music;Religious", "Música", "Música instrumental e som ambiente") ~ "Música",
group_title %in% c("News", "News;Religious", "Notícias", "Notícias em espanhol") ~ "Notícias",
group_title %in% c("Sports", "Esportes") ~ "Esportes",
TRUE ~ group_title # Mantém o valor original se não houver correspondência
)
# Substituir o valor antigo pelo novo no campo group-title
str_replace(linha, paste0("(group-title=')", group_title, "(')"), paste0("\\1", novo_group_title, "\\2"))
}
# Aplicar a função a cada elemento de 'final'
final <- sapply(final, substituir_group_title, USE.NAMES = FALSE)
# Opcional: Salva o conteúdo final em um arquivo
writeLines(final, "conteudo_final.m3u8")
