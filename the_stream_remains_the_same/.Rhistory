simplified_title <- str_replace_all(simplified_title, "Variedades em chinês|Variedades em coreano|Variedades em vários idiomas", "Variedades")
simplified_title <- str_replace_all(simplified_title, "cinema em português|cristianismo em português|educativos e documentários|esportes e e-sports|humor; novelas e séries|infanto-juvenis|lifestyle e realities|maratona de ficção|notícias em português|radios em português|variedades em português", "Brasil")
return(simplified_title)
}
# Aplicar a simplificação e atualizar a variável `final`
final_simplified <- sapply(final, simplify_group_title)
# Lista de tagueamentos não desejados identificados
non_portuguese_tags <- c("Cinema em inglês", "Infantis em alemão", "Infantis em francês", "Infantis em inglês", "Infantis em italiano", "Notícias em inglês", "Novelas e séries em alemão", "Novelas e séries em francês", "Novelas e séries em inglês", "Variedades em espanhol", "Variedades em francês", "Variedades em inglês", "Variedades em russo", "Variedades em turco")
# Filtragem adicional para remover tagueamentos não desejados
final_filtered <- final_simplified[!sapply(final_simplified, function(x) any(str_detect(x, paste(non_portuguese_tags, collapse = "|"))))]
# Mapear e tabular os valores encontrados para `group-title` após a filtragem adicional
group_titles_filtered <- str_extract_all(final_filtered, "group-title=\"[^\"]*\"")
group_titles_filtered <- unlist(group_titles_filtered)
group_titles_filtered <- gsub("group-title=\"", "", group_titles_filtered)
group_titles_filtered <- gsub("\"", "", group_titles_filtered)
# Tabulação dos valores de `group-title` após a filtragem
table(group_titles_filtered)
