# Função para aplicar a simplificação de tags
simplificar_tags <- function(texto, mapeamento) {
for (original in names(mapeamento)) {
simplificado <- mapeamento[[original]]
pattern <- sprintf('group-title="%s"', original)
replacement <- sprintf('group-title="%s"', simplificado)
texto <- gsub(pattern, replacement, texto, ignore.case = TRUE)
}
return(texto)
}
