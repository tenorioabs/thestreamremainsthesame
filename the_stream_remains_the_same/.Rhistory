# Função para substituir valores de group-title
substituir_group_title <- function(linhas) {
sapply(linhas, function(linha) {
group_title <- str_extract(linha, "(?<=group-title=\")[^\"]+(?=\")")
novo_group_title <- "Diversos" # Valor padrão
for (categoria in names(categorias)) {
if (group_title %in% categorias[[categoria]]) {
novo_group_title <- categoria
break
}
}
str_replace(linha, paste0("group-title=\"", group_title, "\""), paste0("group-title=\"", novo_group_title, "\""))
})
}
# Função para substituir valores de group-title
substituir_group_title <- function(linhas) {
sapply(linhas, function(linha) {
group_title <- str_extract(linha, "(?<=group-title=\")[^\"]+(?=\")")
novo_group_title <- "Diversos" # Valor padrão
for (categoria in names(categorias)) {
if (group_title %in% categorias[[categoria]]) {
novo_group_title <- categoria
break
}
}
str_replace(linha, paste0("group-title=\"", group_title, "\""), paste0("group-title=\"", novo_group_title, "\""))
})
}
# Aplicar a função ao vetor 'final'
final <- substituir_group_title(final)
# Opcional: Salva o conteúdo final em um arquivo
writeLines(final, "conteudo_final.m3u8")
